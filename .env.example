# -----------------------------------------------------------------------------
# Frieren Linktree - Environment Variables Configuration Template
# Copy this file to '.env' or set these variables on your deployment platform.
# -----------------------------------------------------------------------------

# --- Umami Analytics ---
# Set these variables to enable website traffic analytics via Umami.
VITE_ANALYTICS_ENDPOINT=https://your-analytics-instance.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id-uuid

# --- Google Maps Integration (Optional) ---
# Used for the Map component, handled automatically via the Manus Proxy in development.
VITE_FRONTEND_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# --- Authentication & Portals (Optional) ---
# Used for OAuth services if auth is integrated.
VITE_OAUTH_PORTAL_URL=https://auth.example.com
VITE_APP_ID=your-app-id
